<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Declares Mosaictor as an editor for image files so it shows up in the
	  system Share Sheet and "Open in / Open With" menus of other apps. The
	  incoming file is delivered to SwiftUI's `.onOpenURL`. This is a partial
	  Info.plist: the remaining keys are still produced by
	  GENERATE_INFOPLIST_FILE and merged in at build time.
	-->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Image</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.image</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
